        "type": "image",
        "return_format": "array",
        "preview_size": "thumbnail",
        "library": "all"
      },
      {
        "key": "field_ss_footer_logo",
        "label": "Footer Logo",
        "name": "footer_logo",
        "type": "image",
        "return_format": "array",
        "preview_size": "thumbnail",
        "library": "all"
      },
      {
        "key": "field_ss_footer_email",
        "label": "Footer Email",
        "name": "footer_email",
        "type": "email",
        "default_value": "hello@mydigitalstride.com"
      },
      {
        "key": "field_ss_footer_phone",
        "label": "Footer Phone",
        "name": "footer_phone",
        "type": "text",
        "default_value": "(717) 123-4567"
      },
      {
        "key": "field_ss_footer_address",
        "label": "Footer Address",
        "name": "footer_address",
        "type": "textarea",
        "rows": 2,
        "default_value": "618 Kings Mill Rd, Suite 101\nYork, PA 17403"
      },
      {
        "key": "field_ss_footer_facebook",
        "label": "Facebook URL",
        "name": "facebook_url",
        "type": "url"
      },
      {
        "key": "field_ss_footer_instagram",
        "label": "Instagram URL",
        "name": "instagram_url",
        "type": "url"
      },
      {
        "key": "field_ss_footer_services_links",
        "label": "Footer Services Links",
        "name": "footer_services_links",
        "type": "repeater",
        "min": 0,
        "max": 10,
        "layout": "row",

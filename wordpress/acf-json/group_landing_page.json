          {
            "key": "field_ss_footer_service_label",
            "label": "Label",
            "name": "label",
            "type": "text"
          },
          {
            "key": "field_ss_footer_service_url",
            "label": "URL",
            "name": "url",
            "type": "url"
          }
        ]
      },
      {
        "key": "field_ss_cta_button_text",
        "label": "Header CTA Button Text",
        "name": "header_cta_text",
        "type": "text",
        "default_value": "Book Your Consultation"
      },
      {
        "key": "field_ss_cta_button_url",
        "label": "Header CTA Button URL",
        "name": "header_cta_url",
        "type": "url"
      }
    ],
    "location": [
      [
        {
          "param": "options_page",
